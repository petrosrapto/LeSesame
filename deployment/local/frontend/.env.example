# Le Sésame Frontend - Local Development Environment Variables
# Copy this file to .env and customize as needed

############### API Configuration #########
# Backend API URL - use localhost for local development
NEXT_PUBLIC_API_URL=http://localhost:8000

# Enable authentication features
NEXT_PUBLIC_ENABLE_AUTH=true
###########################################

############### Google OAuth ###############
# Google OAuth client ID (from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=<your-google-oauth-client-id>
###########################################

############### reCAPTCHA v3 ##############
# Site key (public) from https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=<your-recaptcha-site-key>
###########################################

############### Build Configuration #######
# Node environment
NODE_ENV=development
###########################################
