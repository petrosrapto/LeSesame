# Le Sésame Backend - Local Development Environment Variables
# Copy this file to .env and customize as needed

############### Environment ###############
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
###########################################

############### Server ####################
HOST=0.0.0.0
PORT=8000
###########################################

############### Database ##################
# PostgreSQL connection (set by docker-compose, can override here)
DATABASE_URL=postgresql+asyncpg://le_sesame_user:le_sesame_password@localhost:5432/le_sesame

# PostgreSQL credentials (used by docker-compose)
POSTGRES_DB=le_sesame
POSTGRES_USER=le_sesame_user
POSTGRES_PASSWORD=le_sesame_password
###########################################

############### JWT Authentication ########
# IMPORTANT: Change this in production!
JWT_SECRET=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
###########################################

############### LLM Configuration #########
# Set your API key for real LLM responses
# Leave empty for mock mode (testing)
MISTRAL_API_KEY=
OPENAI_API_KEY=

# Which provider to use: mistral or openai
LLM_PROVIDER=mistral

# Model to use
# Mistral: mistral-small-latest, mistral-medium-latest, mistral-large-latest
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
LLM_MODEL=mistral-small-latest
###########################################

############### Game Configuration ########
# Default secrets/passphrases (loaded from config.yaml in production)
DEFAULT_SECRET=GOLDEN_KEY_2024
DEFAULT_PASSPHRASE=open sesame
###########################################

############### Redis (Optional) ##########
# For session caching (not required for local dev)
REDIS_URL=redis://localhost:6379/0
###########################################

############### CORS Configuration ########
# Allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://frontend:3000"]
###########################################
