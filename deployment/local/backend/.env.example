# Le Sésame Backend - Local Development Environment Variables
# Copy this file to .env and customize as needed

############### Environment ###############
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
###########################################

############### Server ####################
HOST=0.0.0.0
PORT=8000
###########################################

############### Database ##################
# DATABASE_URL is constructed by docker-compose from these variables:
# See docker-compose.yml environment section for the full URL construction.
POSTGRES_DB=<your-database-name, e.g. le_sesame_dev>
POSTGRES_USER=<your-database-user, e.g. le_sesame_user>
POSTGRES_PASSWORD=<your-database-password, e.g. change_me_in_dev>
###########################################

############### JWT Authentication ########
# IMPORTANT: Change this in production!
JWT_SECRET=<your-secure-jwt-secret>
JWT_ALGORITHM=<your-jwt-algorithm, e.g. HS256>
JWT_EXPIRATION_HOURS=<token-expiration-hours, e.g. 24>
###########################################

############### LLM Configuration #########
# Set your API key for real LLM responses
# Leave empty for mock mode (testing)
MISTRAL_API_KEY=<your-mistral-api-key>
OPENAI_API_KEY=<your-openai-api-key>
GOOGLE_API_KEY=<your-google-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# OpenAI-compatible endpoint API keys
# These are used when OPENAI_ENDPOINT_URL points to a non-OpenAI provider
ALIBABA_API_KEY=<your-alibaba-api-key>
DEEPSEEK_API_KEY=<your-deepseek-api-key>
VLLM_API_KEY=<your-vllm-api-key>
TOGETHER_API_KEY=<your-together-api-key>
XAI_API_KEY=<your-xai-api-key>
COHERE_API_KEY=<your-cohere-api-key>

# Custom OpenAI-compatible endpoint URL (optional)
# Examples:
#   https://api.deepseek.com
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   https://api.together.xyz/v1
#   https://api.x.ai/v1
OPENAI_ENDPOINT_URL=<your-openai-compatible-endpoint-url>

# AWS Bedrock credentials
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION_NAME=<your-aws-region, e.g. us-east-1>

# NOTE: LLM provider, model, temperature, max_tokens are configured
# in config.yaml (not here). Per-request overrides are passed via the
# API model_config body parameter.
###########################################

############### LangSmith Tracing #########
# Enable LangSmith tracing for observability
LANGCHAIN_TRACING_V2=<true-or-false>
LANGCHAIN_PROJECT=<your-langchain-project-name, e.g. le-sesame>
LANGCHAIN_API_KEY=<your-langchain-api-key>
LANGCHAIN_ENDPOINT=<your-langchain-endpoint, e.g. https://api.smith.langchain.com>
###########################################

# NOTE: Game level secrets/passphrases are configured in config.local.yaml
# under game.levels (not here).

# NOTE: CORS allowed origins are configured in config.local.yaml
# under security.cors.allowed_origins (not here).
