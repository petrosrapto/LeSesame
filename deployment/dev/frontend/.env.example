# Le Sésame Frontend - Dev Environment Variables
# These are set automatically by CI/CD during deployment
# Copy this file to .env and customize for manual deployment

############### Docker Image (Required) ###
# Set by CI: registry.example.com/le-sesame/frontend:commit-sha
FRONTEND_IMAGE=
###########################################

############### API Configuration #########
# Backend API URL as seen by the BROWSER (baked in at build time).
# "http://backend:8000" will NOT work - browsers can't resolve Docker service names.
# Options:
#   - http://<server-ip>:8000  (if backend port is exposed to the network)
#   - /api                     (if using the Next.js rewrite proxy in next.config.js)
# Set via NEXT_PUBLIC_API_URL GitHub secret for CI builds.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Enable authentication features
NEXT_PUBLIC_ENABLE_AUTH=true
###########################################

############### Build Configuration #######
NODE_ENV=production
###########################################
