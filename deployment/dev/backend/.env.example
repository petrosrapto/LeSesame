# Le Sésame Backend - Dev Environment Variables
# These are set automatically by CI/CD during deployment
# Copy this file to .env and customize for manual deployment

############### Docker Image (Required) ###
# Set by CI: registry.example.com/le-sesame/backend:commit-sha
BACKEND_IMAGE=<your-backend-image>
###########################################

############### Environment ###############
ENVIRONMENT=<your-environment, e.g. production>
DEBUG=<true-or-false, e.g. false>
LOG_LEVEL=<your-log-level, e.g. INFO>
###########################################

############### Server ####################
HOST=0.0.0.0
PORT=8000
###########################################

############### Database ##################
# DATABASE_URL is constructed by docker-compose from these variables:
# See docker-compose.yml environment section for the full URL construction.
POSTGRES_DB=<your-database-name, e.g. le_sesame>
POSTGRES_USER=<your-database-user, e.g. le_sesame_user>
POSTGRES_PASSWORD=<your-database-password, e.g. change_me_in_production>
###########################################

############### JWT Authentication ########
# REQUIRED: Set a strong secret in production!
JWT_SECRET=<your-secure-jwt-secret>
JWT_ALGORITHM=<your-jwt-algorithm, e.g. HS256>
JWT_EXPIRATION_HOURS=<token-expiration-hours, e.g. 24>
###########################################

############### LLM Configuration #########
# At least one API key is required for real LLM responses
MISTRAL_API_KEY=<your-mistral-api-key>
OPENAI_API_KEY=<your-openai-api-key>
GOOGLE_API_KEY=<your-google-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# OpenAI-compatible endpoint API keys
# These are used when OPENAI_ENDPOINT_URL points to a non-OpenAI provider
ALIBABA_API_KEY=<your-alibaba-api-key>
DEEPSEEK_API_KEY=<your-deepseek-api-key>
VLLM_API_KEY=<your-vllm-api-key>
TOGETHER_API_KEY=<your-together-api-key>
XAI_API_KEY=<your-xai-api-key>
COHERE_API_KEY=<your-cohere-api-key>

# Custom OpenAI-compatible endpoint URL (optional)
# Examples:
#   https://api.deepseek.com
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   https://api.together.xyz/v1
#   https://api.x.ai/v1
OPENAI_ENDPOINT_URL=<your-openai-compatible-endpoint-url>

# AWS Bedrock credentials
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION_NAME=<your-aws-region, e.g. us-east-1>

# NOTE: LLM provider, model, temperature, max_tokens are configured
# in config.yaml (not here). Per-request overrides are passed via the
# API model_config body parameter.
###########################################

############### LangSmith Tracing #########
# Enable LangSmith tracing for observability
LANGCHAIN_TRACING_V2=<true-or-false>
LANGCHAIN_PROJECT=<your-langchain-project-name, e.g. le-sesame>
LANGCHAIN_API_KEY=<your-langchain-api-key>
LANGCHAIN_ENDPOINT=<your-langchain-endpoint, e.g. https://api.smith.langchain.com>
###########################################

############### Google OAuth ###############
# Google OAuth client ID (same as frontend NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID)
GOOGLE_OAUTH_CLIENT_ID=<your-google-oauth-client-id>
###########################################

############### reCAPTCHA v3 ##############
# Server-side secret key from https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=<your-recaptcha-secret-key>
RECAPTCHA_SCORE_THRESHOLD=0.5
# Bypass token for e2e tests (set to match the token sent by e2e test suite)
RECAPTCHA_BYPASS_TOKEN=<your-e2e-bypass-token>
###########################################

############### SMTP (Email Verification) #
# For Resend: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_USE_SSL=true
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USE_TLS=true
SMTP_HOST=<your-smtp-host>
SMTP_PORT=<smtp-port, e.g. 587 or 465>
SMTP_USER=<your-smtp-user>
SMTP_PASSWORD=<your-smtp-password-or-api-key>
SMTP_FROM_EMAIL=<your-from-email, e.g. noreply@lesesame.eu>
SMTP_FROM_NAME=Le Sésame
SMTP_USE_TLS=<true-or-false>
SMTP_USE_SSL=<true-or-false>
###########################################

############### Frontend URL ##############
# Used to build email verification links
FRONTEND_URL=<your-frontend-url, e.g. https://lesesame.eu>
###########################################

# NOTE: Game level secrets/passphrases are configured in config.dev.yaml
# under game.levels (not here).

# NOTE: CORS allowed origins are configured in config.dev.yaml
# under security.cors.allowed_origins (not here).
