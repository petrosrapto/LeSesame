# Le Sésame Backend - Dev Environment Variables
# These are set automatically by CI/CD during deployment
# Copy this file to .env and customize for manual deployment

############### Docker Image (Required) ###
# Set by CI: registry.example.com/le-sesame/backend:commit-sha
BACKEND_IMAGE=
###########################################

############### Environment ###############
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
###########################################

############### Server ####################
HOST=0.0.0.0
PORT=8000
###########################################

############### Database ##################
# PostgreSQL connection (set by docker-compose, can override here)
DATABASE_URL=postgresql+asyncpg://le_sesame_user:le_sesame_password@postgres:5432/le_sesame

# PostgreSQL credentials (used by docker-compose)
POSTGRES_DB=le_sesame
POSTGRES_USER=le_sesame_user
POSTGRES_PASSWORD=change_me_in_production
###########################################

############### JWT Authentication ########
# REQUIRED: Set a strong secret in production
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
###########################################

############### LLM Configuration #########
# At least one API key is required for real LLM responses
MISTRAL_API_KEY=
OPENAI_API_KEY=

# Which provider to use: mistral or openai
LLM_PROVIDER=mistral

# Model to use
LLM_MODEL=mistral-small-latest
###########################################

############### Game Configuration ########
DEFAULT_SECRET=GOLDEN_KEY_2024
DEFAULT_PASSPHRASE=open sesame
###########################################

############### Redis (Optional) ##########
REDIS_URL=redis://redis:6379/0
###########################################

############### CORS Configuration ########
# Update with your actual frontend URL
CORS_ORIGINS=["http://frontend:3000","http://localhost:3000"]
###########################################
