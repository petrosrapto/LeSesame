# Le Sésame - Dev Environment - Docker Compose Root Variables
# These variables are used by docker-compose.yml for service configuration.
# Copy this file to .env and fill in the values for manual deployment.
# CI/CD will generate .env automatically from this template + GitHub secrets.

############### Database ##################
POSTGRES_DB=<your-database-name, e.g. le_sesame>
POSTGRES_USER=<your-database-user, e.g. le_sesame_user>
POSTGRES_PASSWORD=<your-database-password>
###########################################

############### Docker Images #############
# Set by CI/CD pipeline with registry and commit SHA
BACKEND_IMAGE=<your-backend-image, e.g. le-sesame-backend:latest>
FRONTEND_IMAGE=<your-frontend-image, e.g. le-sesame-frontend:latest>
###########################################
